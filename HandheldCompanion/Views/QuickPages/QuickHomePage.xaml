<Page
    x:Class="HandheldCompanion.Views.QuickPages.QuickHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:HandheldCompanion.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:l="clr-namespace:HandheldCompanion.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:HandheldCompanion.Properties"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels"
    Name="QuickHome"
    Title="{l:Static resx:Resources.QuickHomePage_Title}"
    Margin="12,0,12,0"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:QuickHomePageViewModel}"
    d:DesignHeight="1200"
    d:DesignWidth="640"
    KeepAlive="True"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:WidthToColumnsConverter x:Key="WidthToColumns" DesiredItemWidth="100" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <ikw:SimpleStackPanel Spacing="8">
            <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.QuickSettingsPage_Title}" />
            <ikw:SimpleStackPanel VerticalAlignment="Top" Spacing="3">
                <!--  Shortcuts  -->
                <ItemsControl
                    HorizontalAlignment="Left"
                    dd:DragDrop.DefaultDragAdornerOpacity="1"
                    dd:DragDrop.DragAdornerTranslation="-50,15"
                    dd:DragDrop.DropHandler="{Binding}"
                    dd:DragDrop.IsDragSource="True"
                    dd:DragDrop.IsDropTarget="True"
                    dd:DragDrop.UseDefaultDragAdorner="True"
                    ItemsSource="{Binding HotkeysList}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel
                                ItemHeight="160"
                                ItemWidth="100"
                                Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <!--  Double-execute indicator: shown only when the command supports a double-tap action  -->
                                <!--
                                <ui:FontIcon
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Foreground="{DynamicResource AccentAAFillColorDefaultBrush}"
                                    Icon="{x:Static ui:SegoeFluentIcons.Click}"
                                    ToolTip="This hotkey supports a double-tap action">
                                    <ui:FontIcon.Style>
                                        <Style TargetType="ui:FontIcon">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDoubleExecute}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:FontIcon.Style>
                                </ui:FontIcon>
                                -->

                                <ikw:SimpleStackPanel Spacing="3">
                                    <ToggleButton
                                        Height="100"
                                        Margin="3"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Command="{Binding ExecuteCommand}"
                                        IsChecked="{Binding IsToggled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding IsEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        Tag="Hotkey">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="50px" />
                                                <RowDefinition Height="5px" />
                                                <RowDefinition Height="30px" />
                                            </Grid.RowDefinitions>

                                            <ui:FontIcon
                                                Width="24"
                                                Height="24"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{Binding FontFamily, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                FontSize="{Binding FontSize, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                Glyph="{Binding LiveGlyph, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ui:FontIcon.Style>
                                                    <Style TargetType="ui:FontIcon">
                                                        <Setter Property="Grid.RowSpan" Value="1" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasTriggerChord}" Value="False">
                                                                <Setter Property="Grid.RowSpan" Value="3" />
                                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:FontIcon.Style>
                                            </ui:FontIcon>

                                            <Separator
                                                Grid.Row="1"
                                                BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                                BorderThickness="0,1,0,0"
                                                Opacity="0.25">
                                                <Separator.Style>
                                                    <Style TargetType="Separator">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasTriggerChord}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Separator.Style>
                                            </Separator>

                                            <ItemsControl
                                                Grid.Row="2"
                                                HorizontalAlignment="Center"
                                                ItemsSource="{Binding TriggerChordParts, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ItemsControl.Style>
                                                    <Style TargetType="ItemsControl">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasTriggerChord}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.Style>

                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="1" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            Height="24"
                                                            MinWidth="24"
                                                            Background="{DynamicResource NavigationViewContentGridBorderBrush}"
                                                            CornerRadius="3">
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontFamily="{Binding FontFamily}"
                                                                FontSize="{Binding FontSize}"
                                                                Text="{Binding Glyph}"
                                                                TextAlignment="Center"
                                                                TextWrapping="Wrap" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </ToggleButton>

                                    <TextBlock
                                        FontSize="12"
                                        Text="{Binding LiveName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextAlignment="Center"
                                        TextWrapping="Wrap" />
                                </ikw:SimpleStackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ikw:SimpleStackPanel>
        </ikw:SimpleStackPanel>

        <ikw:SimpleStackPanel
            Grid.Row="1"
            VerticalAlignment="Bottom"
            Spacing="12">

            <ui:NavigationViewItemSeparator Margin="-15,0,-6,0" />

            <DockPanel>
                <ui:FontIcon
                    Height="40"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource SymbolThemeFontFamily}"
                    Glyph="&#xE706;" />

                <ikw:SimpleStackPanel Margin="12,0,12,0" VerticalAlignment="Center">
                    <Slider
                        x:Name="SliderBrightness"
                        IsEnabled="False"
                        IsMoveToPointEnabled="True"
                        IsSnapToTickEnabled="True"
                        LargeChange="10"
                        Maximum="100"
                        Minimum="0"
                        SmallChange="1"
                        TickFrequency="1"
                        ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                        ValueChanged="SliderBrightness_ValueChanged" />
                </ikw:SimpleStackPanel>
            </DockPanel>

            <DockPanel>
                <ui:FontIcon
                    Name="VolumeIcon"
                    Height="40"
                    HorizontalAlignment="Center"
                    FontFamily="{DynamicResource SymbolThemeFontFamily}"
                    Glyph="&#xE767;" />

                <ikw:SimpleStackPanel Margin="12,0,12,0" VerticalAlignment="Center">
                    <Slider
                        x:Name="SliderVolume"
                        IsMoveToPointEnabled="True"
                        IsSnapToTickEnabled="True"
                        LargeChange="10"
                        Maximum="100"
                        Minimum="0"
                        SmallChange="1"
                        TickFrequency="1"
                        ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                        ValueChanged="SliderVolume_ValueChanged" />
                </ikw:SimpleStackPanel>
            </DockPanel>
        </ikw:SimpleStackPanel>
    </Grid>
</Page>