<Page
    x:Class="HandheldCompanion.Views.QuickPages.QuickProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:l="clr-namespace:HandheldCompanion.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:HandheldCompanion.Properties"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels"
    Name="QuickProfiles"
    Title="{l:Static resx:Resources.QuickProfilesPage_Title}"
    Margin="12,0,12,0"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:ProfilesPageViewModel}"
    d:DesignHeight="2200"
    d:DesignWidth="640"
    KeepAlive="True"
    mc:Ignorable="d">

    <ikw:SimpleStackPanel IsEnabled="{Binding HasSelectedProfile, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Spacing="28">

        <!--  Header  -->
        <ui:SettingsExpander
            Name="ProcessCard"
            d:IsExpanded="True"
            IsEnabled="{Binding IsProcessCardEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
            <ui:SettingsExpander.HeaderIcon>
                <Image
                    Name="ProfileIcon"
                    Grid.Column="0"
                    Width="24"
                    Height="24"
                    Source="{Binding ProcessIcon, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
            </ui:SettingsExpander.HeaderIcon>

            <ui:SettingsExpander.Header>
                <TextBlock
                    Name="ProcessName"
                    VerticalAlignment="Center"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="{Binding ProcessName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
            </ui:SettingsExpander.Header>

            <ui:SettingsExpander.Description>
                <TextBlock
                    Name="ProcessPath"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{Binding ProcessPath, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="NoWrap"
                    Visibility="{Binding IsProcessPathVisible, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </ui:SettingsExpander.Description>

            <ui:SettingsExpander.Items>
                <ui:SettingsCard Header="{l:Static resx:Resources.ProfilesPage_EnableProfile}">
                    <ui:SettingsCard.Description>
                        <TextBlock
                            Name="CurrentProfileName"
                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{Binding CurrentProfileName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="NoWrap" />
                    </ui:SettingsCard.Description>

                    <ui:ToggleSwitch Name="ProfileToggle" IsOn="{Binding ProfileEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </ui:SettingsCard>

                <!--  Sub Profiles  -->
                <ui:SettingsCard
                    Name="SubProfilesBorder"
                    d:Visibility="Visible"
                    Description="{l:Static resx:Resources.QuickProfilesPage_SubProfilesDesc}"
                    Header="{l:Static resx:Resources.ProfilesPage_SubProfiles}"
                    Visibility="{Binding IsSubProfilesVisible, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <ui:SettingsCard.Resources>
                        <sys:Double x:Key="SettingsCardWrapThreshold">476</sys:Double>
                        <sys:Double x:Key="SettingsCardWrapNoIconThreshold">286</sys:Double>
                    </ui:SettingsCard.Resources>

                    <ComboBox
                        Name="SelectSubProfileComboBox"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding SubProfilesView, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                        SelectedItem="{Binding SelectedSubProfileViewModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </ui:SettingsCard>

                <ui:SettingsCard
                    Command="{Binding OpenProfilePageCommand}"
                    Header="{l:Static resx:Resources.ProfilesPage_OpenProfilePage}"
                    IsClickEnabled="True"
                    Tag="Navigation" />

                <ui:SettingsCard
                    Command="{Binding OpenProfileLayoutCommand}"
                    Header="{l:Static resx:Resources.ProfilesPage_OpenLayoutPage}"
                    IsClickEnabled="True"
                    Tag="Navigation" />
            </ui:SettingsExpander.Items>
        </ui:SettingsExpander>

        <ikw:SimpleStackPanel Name="GridProfile" Spacing="28">

            <!--  Power Settings  -->
            <ikw:SimpleStackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource BaseTextBlockStyle}"
                    Text="{l:Static resx:Resources.ProfilesPage_PowerSettings}"
                    Visibility="{Binding PerformanceManagerEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ikw:SimpleStackPanel Spacing="3" Visibility="{Binding PerformanceManagerEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:SettingsExpander
                        d:IsExpanded="True"
                        Description="{l:Static resx:Resources.ProfilesPage_PowerPresetDesc}"
                        Header="{l:Static resx:Resources.ProfilesPage_PowerPreset}">
                        <ui:SettingsExpander.HeaderIcon>
                            <ui:FontIcon Glyph="&#xec4a;" />
                        </ui:SettingsExpander.HeaderIcon>

                        <TextBlock
                            Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{Binding SelectedPowerProfileName, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ui:SettingsExpander.Items>
                            <ui:SettingsCard
                                Command="{Binding OpenPowerProfileOnBatteryCommand}"
                                Header="On battery"
                                IsClickEnabled="True"
                                Tag="Navigation">
                                <ComboBox
                                    Name="PowerProfileOnBattery"
                                    DisplayMemberPath="Text"
                                    ItemContainerStyle="{StaticResource {x:Type ComboBoxItem}}"
                                    ItemsSource="{Binding ProfilePickerCollectionViewDC, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedItem="{Binding SelectedPickerDC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Text">
                                    <ComboBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock
                                                        Margin="4,0,0,0"
                                                        Style="{StaticResource BaseTextBlockStyle}"
                                                        Text="{Binding Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ComboBox.GroupStyle>
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Command="{Binding OpenPowerProfilePluggedCommand}"
                                Header="Plugged in"
                                IsClickEnabled="True"
                                Tag="Navigation">
                                <ComboBox
                                    Name="PowerProfilePlugged"
                                    DisplayMemberPath="Text"
                                    ItemContainerStyle="{StaticResource {x:Type ComboBoxItem}}"
                                    ItemsSource="{Binding ProfilePickerCollectionViewAC, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedItem="{Binding SelectedPickerAC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SelectedValuePath="Text">
                                    <ComboBox.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock
                                                        Margin="4,0,0,0"
                                                        Style="{StaticResource BaseTextBlockStyle}"
                                                        Text="{Binding Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ComboBox.GroupStyle>
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Command="{Binding CreatePowerProfileCommand}"
                                Header="{l:Static resx:Resources.ProfilesPage_CreatePowerProfile}"
                                IsClickEnabled="True" />
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </ikw:SimpleStackPanel>
            </ikw:SimpleStackPanel>

            <!--  Motion control settings  -->
            <ikw:SimpleStackPanel Spacing="8">
                <TextBlock Style="{StaticResource BaseTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_InputsSettings}" />

                <ui:SettingsExpander
                    d:IsExpanded="true"
                    Description="{l:Static resx:Resources.ProfilesPage_MotionControlSettingsDesc}"
                    Header="{l:Static resx:Resources.ProfilesPage_MotionControlSettings}"
                    IsExpanded="False">
                    <ui:SettingsExpander.HeaderIcon>
                        <ui:FontIcon Glyph="&#xE8B4;" />
                    </ui:SettingsExpander.HeaderIcon>

                    <TextBlock
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{Binding OutputMode, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource MotionOutputToNameConverter}}" />

                    <ui:SettingsExpander.Items>
                        <ui:SettingsCard Description="{l:Static resx:Resources.ProfilesPage_UMCSelectionRightLeftDesc}" Header="{l:Static resx:Resources.ProfilesPage_StyleofOutput}">
                            <ComboBox Name="MotionOutputComboBox" SelectedIndex="{Binding OutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <ui:SettingsCard
                            Description="{l:Static resx:Resources.ProfilesPage_StyleofInputTooltip}"
                            Header="{l:Static resx:Resources.ProfilesPage_StyleofInput}"
                            Visibility="{Binding OutputMode, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1|2|3|4|5}">
                            <ComboBox Name="MotionInputComboBox" SelectedIndex="{Binding InputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <ui:SettingsCard
                            ContentAlignment="Vertical"
                            Header="{l:Static resx:Resources.ProfilesPage_UMCMotionOnOff}"
                            Visibility="{Binding OutputMode, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1|2|3|4|5}">

                            <ikw:SimpleStackPanel Spacing="3">
                                <ComboBox
                                    Name="MotionModeComboBox"
                                    HorizontalAlignment="Stretch"
                                    SelectedIndex="{Binding MotionMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_UMCMotionOff}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_UMCMotionOn}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_UMCMotionToggle}" />
                                </ComboBox>

                                <ItemsControl ItemsSource="{Binding HotkeysList}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition MaxWidth="50" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition MinWidth="90" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Padding="6"
                                                    HorizontalAlignment="Stretch"
                                                    Background="{DynamicResource ExpanderHeaderBackground}"
                                                    CornerRadius="3">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasTriggerChord}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Text="{Binding InputsChordType, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </Border>

                                                <ItemsControl
                                                    Grid.Column="1"
                                                    Margin="3,0,0,0"
                                                    ItemsSource="{Binding TriggerChordParts}">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasTriggerChord}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsExecuted}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation
                                                                                    AutoReverse="True"
                                                                                    FillBehavior="Stop"
                                                                                    RepeatBehavior="1x"
                                                                                    Storyboard.TargetProperty="Opacity"
                                                                                    From="1.0"
                                                                                    To="0.0"
                                                                                    Duration="0:0:0.125" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>

                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="1" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                MinWidth="40"
                                                                HorizontalAlignment="Stretch"
                                                                Background="{DynamicResource AccentAAFillColorDefaultBrush}"
                                                                CornerRadius="3">
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontFamily="{Binding FontFamily, FallbackValue={StaticResource SymbolThemeFontFamily}, TargetNullValue={StaticResource SymbolThemeFontFamily}}"
                                                                    FontSize="{Binding FontSize}"
                                                                    Foreground="{Binding Color, Converter={StaticResource ColorToBrushConverter}, FallbackValue={StaticResource SystemControlForegroundAltHighBrush}}"
                                                                    Text="{Binding Glyph}"
                                                                    TextAlignment="Center"
                                                                    TextWrapping="NoWrap" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <ikw:SimpleStackPanel
                                                    Grid.Column="2"
                                                    Height="40"
                                                    Margin="12,0,0,0"
                                                    HorizontalAlignment="Right"
                                                    Orientation="Horizontal"
                                                    Spacing="3">

                                                    <ToggleButton
                                                        VerticalAlignment="Stretch"
                                                        Command="{Binding DefineButtonCommand}"
                                                        IsChecked="{Binding IsListening, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Tag="Hotkey">
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe104;" />
                                                    </ToggleButton>

                                                    <Button VerticalAlignment="Stretch" Command="{Binding EraseButtonCommand}">
                                                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe75c;" />
                                                    </Button>
                                                </ikw:SimpleStackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ikw:SimpleStackPanel>
                        </ui:SettingsCard>

                        <ui:SettingsCard
                            ContentAlignment="Vertical"
                            Description="{l:Static resx:Resources.ProfilesPage_UMCAntiDeadzoneDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_UMCAntiDeadzone}"
                            Visibility="{Binding OutputMode, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1|2|3|4|5}">
                            <DockPanel>
                                <TextBox
                                    Height="31"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    IsReadOnly="True"
                                    Text="{Binding AntiDeadzoneValue, StringFormat={}{0:N0}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    AutoToolTipPrecision="0"
                                    IsMoveToPointEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    LargeChange="10"
                                    Maximum="40"
                                    SmallChange="1"
                                    TickPlacement="BottomRight"
                                    ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                    Value="{Binding AntiDeadzoneValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </ui:SettingsCard>

                        <!--  Gyrometer weight  -->
                        <ui:SettingsCard
                            ContentAlignment="Vertical"
                            Description="Modify the gyrometer weight when applied against joystick movements"
                            Header="Gyrometer weight"
                            Visibility="{Binding OutputMode, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1|2|3|4|5}">
                            <DockPanel>
                                <TextBox
                                    Height="31"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    IsReadOnly="True"
                                    Text="{Binding GyroWeightValue, StringFormat={}{0:N1}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    AutoToolTipPrecision="1"
                                    IsMoveToPointEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    Maximum="2.0"
                                    Minimum="1.0"
                                    TickFrequency="0.1"
                                    TickPlacement="BottomRight"
                                    ToolTip="{Binding Value, StringFormat=N1, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                    Value="{Binding GyroWeightValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </ui:SettingsCard>

                        <!--  Horizontal sensitivity  -->
                        <ui:SettingsCard
                            ContentAlignment="Vertical"
                            Header="Horizontal sensitivity"
                            Visibility="{Binding OutputMode, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1|2|3|4|5}">
                            <DockPanel>
                                <TextBox
                                    Height="31"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    IsReadOnly="True"
                                    Text="{Binding SensitivityXValue, StringFormat={}{0:N1}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider
                                    x:Name="SensitivityXValue"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    AutoToolTipPrecision="1"
                                    IsMoveToPointEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    LargeChange="0.1"
                                    Maximum="3.0"
                                    Minimum="0.1"
                                    SmallChange="0.1"
                                    TickFrequency="0.1"
                                    TickPlacement="BottomRight"
                                    ToolTip="{Binding Value, StringFormat=N1, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                    Value="{Binding SensitivityXValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </ui:SettingsCard>

                        <!--  Vertical sensitivity  -->
                        <ui:SettingsCard
                            ContentAlignment="Vertical"
                            Header="Vertical sensitivity"
                            Visibility="{Binding OutputMode, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=1|2|3|4|5}">
                            <DockPanel>
                                <TextBox
                                    Height="31"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    IsReadOnly="True"
                                    Text="{Binding SensitivityYValue, StringFormat={}{0:N1}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider
                                    x:Name="SliderSensitivityY"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    AutoToolTipPrecision="1"
                                    IsMoveToPointEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    LargeChange="0.1"
                                    Maximum="3.0"
                                    Minimum="0.1"
                                    SmallChange="0.1"
                                    TickFrequency="0.1"
                                    TickPlacement="BottomRight"
                                    ToolTip="{Binding Value, StringFormat=N1, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                    Value="{Binding SensitivityYValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </ui:SettingsCard>
                    </ui:SettingsExpander.Items>
                </ui:SettingsExpander>
            </ikw:SimpleStackPanel>

            <!--  Graphics settings  -->
            <ikw:SimpleStackPanel Spacing="8">
                <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{l:Static resx:Resources.ProfilesPage_GraphicsSettings}" />

                <ui:SettingsExpander
                    Name="GraphicsSettingsExpander"
                    d:IsExpanded="true"
                    Description="{l:Static resx:Resources.ProfilesPage_GraphicsSettingsDesc}"
                    Header="{l:Static resx:Resources.ProfilesPage_GraphicsSettings}"
                    Visibility="{Binding GPUManagementEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:SettingsExpander.HeaderIcon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE790;" />
                    </ui:SettingsExpander.HeaderIcon>

                    <ui:SettingsExpander.Items>
                        <!--  GPU Scaling  -->
                        <ui:SettingsCard
                            Description="{l:Static resx:Resources.ProfilesPage_GPUScalingDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_GPUScaling}"
                            IsEnabled="{Binding HasGPUScalingSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                            <ui:ToggleSwitch IsOn="{Binding GPUScalingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  GPU Scaling Mode  -->
                        <ui:SettingsCard
                            Description="{l:Static resx:Resources.ProfilesPage_GPUScalingDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_ScalingMode}"
                            Visibility="{Binding GPUScalingEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <ComboBox Name="GPUScalingComboBox" SelectedIndex="{Binding ScalingModeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_ScalingMode_PreserveAspectRatio}" />
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_ScalingMode_FullPanel}" />
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_ScalingMode_Center}" IsEnabled="{Binding RSREnabled, Converter={StaticResource InvertBooleanConverter}}" />
                            </ComboBox>
                        </ui:SettingsCard>

                        <!--  RSR (AMD)  -->
                        <ui:SettingsCard
                            Name="RSRCard"
                            d:Background="Red"
                            d:Visibility="Visible"
                            Description="{l:Static resx:Resources.ProfilesPage_RSRDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_RSR}"
                            IsEnabled="{Binding HasRSRSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                            <ui:ToggleSwitch Name="RSRToggle" IsOn="{Binding RSREnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  RSR Value Slider  -->
                        <ui:SettingsCard
                            ContentAlignment="Vertical"
                            Header="{l:Static resx:Resources.ProfilesPage_RSR}"
                            IsEnabled="{Binding RSREnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding HasRSRSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <DockPanel>
                                <TextBox
                                    Width="60"
                                    Height="31"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    IsReadOnly="True"
                                    Text="{Binding RSRValue, StringFormat={}{0:N0}%, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider
                                    x:Name="RSRSlider"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    AutoToolTipPrecision="0"
                                    IsMoveToPointEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    LargeChange="5"
                                    Maximum="100"
                                    Minimum="0"
                                    SmallChange="1"
                                    TickFrequency="5"
                                    TickPlacement="BottomRight"
                                    ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                    Value="{Binding RSRValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </ui:SettingsCard>

                        <!--  AFMF (AMD)  -->
                        <ui:SettingsCard
                            d:Background="Red"
                            d:Visibility="Visible"
                            Description="{l:Static resx:Resources.ProfilesPage_AFMFDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_AFMF}"
                            IsEnabled="{Binding HasAFMFSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding IsAMDGPU, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <ui:ToggleSwitch IsOn="{Binding AFMFEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  AFMF Algorithm  -->
                        <ui:SettingsCard
                            d:Visibility="Visible"
                            Description="{l:Static resx:Resources.ProfilesPage_AFMFAlgorithmDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_AFMFAlgorithm}"
                            IsEnabled="{Binding HasAFMF21Support, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding AFMFEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <ComboBox MinWidth="150" SelectedIndex="{Binding AFMFAlgorithm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_AFMFAlgorithm_Auto}" />
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_AFMFAlgorithm_Enhanced}" />
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_AFMFAlgorithm_Standard}" />
                            </ComboBox>
                        </ui:SettingsCard>

                        <!--  AFMF Performance Mode  -->
                        <ui:SettingsCard
                            d:Visibility="Visible"
                            Description="{l:Static resx:Resources.ProfilesPage_AFMFPerformanceModeDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_AFMFPerformanceMode}"
                            IsEnabled="{Binding HasAFMF21Support, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding AFMFEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <ComboBox MinWidth="150" SelectedIndex="{Binding AFMFPerformanceMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_AFMFPerformanceMode_Auto}" />
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_AFMFPerformanceMode_Quality}" />
                                <ComboBoxItem Content="{l:Static resx:Resources.ProfilesPage_AFMFPerformanceMode_Performance}" />
                            </ComboBox>
                        </ui:SettingsCard>

                        <!--  Integer Scaling  -->
                        <ui:SettingsCard
                            Description="{l:Static resx:Resources.ProfilesPage_ISDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_IS}"
                            IsEnabled="{Binding HasIntegerScalingSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                            <ui:ToggleSwitch IsOn="{Binding IntegerScalingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  Resolution Scale  -->
                        <ui:SettingsCard
                            Description="{l:Static resx:Resources.ProfilesPage_ResolutionScaleDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_ResolutionScale}"
                            Visibility="{Binding IntegerScalingEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <ComboBox
                                MinWidth="150"
                                ItemsSource="{Binding IntegerScalingDividers}"
                                SelectedIndex="{Binding IntegerScalingDividerIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  Exclusive Fullscreen Warning  -->
                        <!--
                        <ui:InfoBar
                            Title="{l:Static resx:Resources.QuickSettingsPage_ResScaleExclusiveFullscreen}"
                            d:Visibility="Visible"
                            Visibility="{Binding IntegerScalingDividerIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=0}" />

                        <ui:SettingsCard
                            d:Visibility="Visible"
                            Header="{l:Static resx:Resources.QuickSettingsPage_ResScaleExclusiveFullscreen}"
                            IsEnabled="{Binding IntegerScalingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Visibility="{Binding IntegerScalingDividerIndex, Converter={StaticResource IndexToVisibilityConverter}, ConverterParameter=0}">

                            <ui:SettingsCard.HeaderIcon>
                                <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xe7ba;" />
                            </ui:SettingsCard.HeaderIcon>
                        </ui:SettingsCard>
                        -->

                        <!--  Resolution Scale Type  -->
                        <ui:SettingsCard
                            Description="{l:Static resx:Resources.ProfilesPage_ResolutionScaleTypeDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_ResolutionScaleType}"
                            Visibility="{Binding IntegerScalingEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <ComboBox
                                Name="IntegerScalingTypeComboBox"
                                MinWidth="150"
                                SelectedIndex="{Binding IntegerScalingTypeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Name="IntegerScalingTypeInteger" Content="{l:Static resx:Resources.ProfilesPage_ResolutionScaleTypeInteger}" />
                                <ComboBoxItem Name="IntegerScalingTypeNearest" Content="{l:Static resx:Resources.ProfilesPage_ResolutionScaleTypeNearest}" />
                            </ComboBox>
                        </ui:SettingsCard>

                        <!--  RIS (Image Sharpening)  -->
                        <ui:SettingsCard
                            Name="RISCard"
                            Description="{l:Static resx:Resources.ProfilesPage_ImageSharpeningDesc}"
                            Header="{l:Static resx:Resources.ProfilesPage_ImageSharpening}"
                            IsEnabled="{Binding HasGPUScalingSupport, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">

                            <ui:ToggleSwitch Name="RISToggle" IsOn="{Binding RISEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </ui:SettingsCard>

                        <!--  RIS Value Slider  -->
                        <ui:SettingsCard
                            ContentAlignment="Vertical"
                            Header="{l:Static resx:Resources.ProfilesPage_ImageSharpening}"
                            Visibility="{Binding RISEnabled, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <DockPanel>
                                <TextBox
                                    Width="60"
                                    Height="31"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    IsReadOnly="True"
                                    Text="{Binding RISValue, StringFormat={}{0:N0}%, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Slider
                                    x:Name="RISSlider"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    AutoToolTipPrecision="0"
                                    IsMoveToPointEnabled="True"
                                    IsSnapToTickEnabled="True"
                                    LargeChange="5"
                                    Maximum="100"
                                    Minimum="0"
                                    SmallChange="1"
                                    TickFrequency="5"
                                    TickPlacement="BottomRight"
                                    ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                    Value="{Binding RISValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </ui:SettingsCard>
                    </ui:SettingsExpander.Items>
                </ui:SettingsExpander>
            </ikw:SimpleStackPanel>
        </ikw:SimpleStackPanel>
    </ikw:SimpleStackPanel>
</Page>
