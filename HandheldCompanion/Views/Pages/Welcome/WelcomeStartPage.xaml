<Page
    x:Class="HandheldCompanion.Views.Pages.Welcome.WelcomeStartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:HandheldCompanion.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels.Windows"
    Title="Welcome"
    Margin="48"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:WelcomeViewModel}"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ikw:SimpleStackPanel
            MaxWidth="460"
            VerticalAlignment="Center"
            Orientation="Vertical"
            Spacing="18">
            <TextBlock
                behaviors:TextBlockUpperCase.IsUpperCase="True"
                Style="{StaticResource CapitalAccentTextBlockStyle}"
                Text="hello there." />
            <TextBlock
                Style="{StaticResource TitleBoldTextBlockStyle}"
                Text="Welcome to Handheld Companion."
                TextWrapping="Wrap" />
            <TextBlock
                Style="{StaticResource BodyTextBlockStyle}"
                Text="Over the next few steps, HC will confirm your detected device and prepare a few important defaults. You can change anything later from Settings."
                TextWrapping="Wrap" />
        </ikw:SimpleStackPanel>

        <TextBlock
            Grid.Column="1"
            VerticalAlignment="Center"
            FontSize="220"
            FontWeight="Black"
            Foreground="#FFFEB635"
            Text="HC"
            TextAlignment="Center" />
    </Grid>
</Page>
