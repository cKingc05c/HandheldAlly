<Page
    x:Class="HandheldCompanion.Views.Pages.Welcome.WelcomeFinishPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels.Windows"
    Title="Done"
    Margin="48"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:WelcomeViewModel}"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">

    <ikw:SimpleStackPanel
        MaxWidth="840"
        VerticalAlignment="Center"
        Spacing="20">
        <ui:FontIcon
            HorizontalAlignment="Center"
            FontFamily="{DynamicResource SymbolThemeFontFamily}"
            FontSize="96"
            Foreground="{DynamicResource SystemAccentColorLight2Brush}"
            Glyph="&#xE930;" />
        <TextBlock
            HorizontalAlignment="Center"
            Style="{StaticResource TitleBoldTextBlockStyle}"
            Text="You're ready to start."
            TextWrapping="Wrap" />
        <TextBlock
            Style="{StaticResource BodyTextBlockStyle}"
            Text="HC will save these choices and continue startup. You can revisit all options later from Settings."
            TextAlignment="Center"
            TextWrapping="Wrap" />

        <ui:SettingsCard Description="Detected device" Header="{Binding DeviceName}">
            <ui:SettingsCard.HeaderIcon>
                <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.XboxOneConsole}" />
            </ui:SettingsCard.HeaderIcon>
        </ui:SettingsCard>
    </ikw:SimpleStackPanel>
</Page>
