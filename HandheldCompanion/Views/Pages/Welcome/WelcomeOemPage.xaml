<Page
    x:Class="HandheldCompanion.Views.Pages.Welcome.WelcomeOemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:HandheldCompanion.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:l="clr-namespace:HandheldCompanion.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:HandheldCompanion.Properties"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels.Windows"
    Title="OEM stack"
    Margin="48"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:WelcomeViewModel}"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">

    <Grid MaxWidth="840" VerticalAlignment="Center">
        <ikw:SimpleStackPanel Spacing="18">
            <TextBlock
                behaviors:TextBlockUpperCase.IsUpperCase="True"
                Style="{StaticResource CapitalAccentTextBlockStyle}"
                Text="oem software" />
            <TextBlock
                Style="{StaticResource SubtitleBoldTextBlockStyle}"
                Text="Avoid device-control conflicts."
                TextWrapping="Wrap" />
            <TextBlock
                Style="{StaticResource BodyTextBlockStyle}"
                Text="Some manufacturer utilities can compete with HC for controls, services, tasks, buttons, or performance settings."
                TextWrapping="Wrap" />

            <ikw:SimpleStackPanel Spacing="3">
                <ui:InfoBar
                    Title="Reversible choice"
                    IsOpen="True"
                    Message="This can be restored later by HC restore logic or by enabling the OEM stack again."
                    Severity="Informational"
                    Visibility="{Binding OemStackVisibility}" />

                <ui:SettingsCard Header="Let HC manage the device instead of the OEM utility" Visibility="{Binding OemStackVisibility}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE711;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:SettingsCard.Description>
                        <TextBlock Text="Prevent conflicting OEM software from starting while Handheld Companion manages your device." />
                    </ui:SettingsCard.Description>
                    <ui:ToggleSwitch IsOn="{Binding DisableOemStack, Mode=TwoWay}" />
                </ui:SettingsCard>

                <ui:SettingsCard
                    Description="HC will continue without changing OEM tasks or services."
                    Header="No supported OEM stack detected"
                    Visibility="{Binding NoOemStackVisibility}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon
                            FontFamily="{DynamicResource SymbolThemeFontFamily}"
                            Foreground="{DynamicResource SystemAccentColorLight2Brush}"
                            Glyph="&#xE930;" />
                    </ui:SettingsCard.HeaderIcon>
                </ui:SettingsCard>

                <ui:SettingsCard Description="{l:Static resx:Resources.DevicePage_CoreIsolationDesc}" Header="{l:Static resx:Resources.DevicePage_CoreIsolation}">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE705;" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch IsOn="{Binding CoreIsolation, Mode=TwoWay}" />
                </ui:SettingsCard>

                <ui:InfoBar
                    Title="Device restart required"
                    IsClosable="False"
                    IsOpen="{Binding RestartRequired}"
                    Message="Your changes require a restart to take effect. The device will restart when you close this setup."
                    Severity="Warning" />
            </ikw:SimpleStackPanel>

            <TextBlock
                behaviors:TextBlockUpperCase.IsUpperCase="True"
                Style="{StaticResource CapitalAccentTextBlockStyle}"
                Text="COMPONENTS" />
            <ikw:SimpleStackPanel Spacing="3">
                <ui:SettingsCard Description="Enable or disable all TDP, CPU and GPU frequency overrides managed by the performance manager" Header="Performance management">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.SpeedHigh}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch IsOn="{Binding PerformanceManagerEnabled, Mode=TwoWay}" />
                </ui:SettingsCard>
                <ui:SettingsCard Description="Enable or disable GPU management settings such as RSR, Integer Scaling, AFMF and image sharpening" Header="GPU management">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.TVMonitor}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch IsOn="{Binding GpuManagementEnabled, Mode=TwoWay}" />
                </ui:SettingsCard>
                <ui:SettingsCard Description="Enable or disable the built-in game library management. Disable this if you use your own library software" Header="Library management">
                    <ui:SettingsCard.HeaderIcon>
                        <ui:FontIcon Icon="{x:Static ui:SegoeFluentIcons.Library}" />
                    </ui:SettingsCard.HeaderIcon>
                    <ui:ToggleSwitch IsOn="{Binding LibraryPageEnabled, Mode=TwoWay}" />
                </ui:SettingsCard>
            </ikw:SimpleStackPanel>
        </ikw:SimpleStackPanel>
    </Grid>
</Page>
