<Page
    x:Class="HandheldCompanion.Views.Pages.OverlayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:HandheldCompanion.Behaviors"
    xmlns:colorpicker="clr-namespace:ColorPicker;assembly=ColorPicker"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
    xmlns:l="clr-namespace:HandheldCompanion.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:HandheldCompanion.Properties"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodels="clr-namespace:HandheldCompanion.ViewModels"
    Name="Overlay"
    Title="{l:Static resx:Resources.OverlayPage_Overlay}"
    Margin="20"
    d:Background="White"
    d:DataContext="{d:DesignInstance Type=viewmodels:OverlayPageViewModel}"
    d:DesignHeight="2200"
    d:DesignWidth="1000"
    KeepAlive="True"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <StackPanel>
        <TextBlock
            Margin="0,0,0,8"
            behaviors:TextBlockUpperCase.IsUpperCase="True"
            Style="{StaticResource CapitalAccentTextBlockStyle}"
            Text="{Binding Name, RelativeSource={RelativeSource AncestorType=Page}}" />

        <ikw:SimpleStackPanel Spacing="28">
            <!--  OSD options  -->
            <ikw:SimpleStackPanel Spacing="8">
                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource BaseTextBlockStyle}"
                        Text="{l:Static resx:Resources.OverlayPage_OnScreenDisplayOptions}" />
                    <TextBlock
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        Text="Update rate, display level and RTSS integration" />
                </DockPanel>

                <ikw:SimpleStackPanel Spacing="3">
                    <!--  On-screen display update rate  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_OverlayDisplayUpdateRateDesc}" Header="{l:Static resx:Resources.OverlayPage_OverlayDisplayUpdateRate}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE823;" />
                        </ui:SettingsCard.HeaderIcon>
                        <DockPanel>
                            <TextBox
                                Height="31"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                IsReadOnly="True"
                                Text="{Binding Value, StringFormat={}{0:N0} ms, ElementName=SliderOnScreenUpdateRate, Mode=OneWay}" />
                            <Slider
                                x:Name="SliderOnScreenUpdateRate"
                                Width="200"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                IsSnapToTickEnabled="True"
                                LargeChange="1000"
                                Maximum="4000"
                                Minimum="500"
                                SmallChange="100"
                                TickFrequency="100"
                                TickPlacement="BottomRight"
                                ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                ValueChanged="SliderOnScreenUpdateRate_ValueChanged" />
                        </DockPanel>
                    </ui:SettingsCard>

                    <!--  On-screen display level  -->
                    <ui:SettingsExpander
                        Name="OnScreenDisplayLevelExpander"
                        Description="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevelDesc}"
                        Header="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevel}"
                        IsEnabled="{Binding IsRunningRTSS}">
                        <ui:SettingsExpander.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE78B;" />
                        </ui:SettingsExpander.HeaderIcon>
                        <ComboBox
                            Name="OnScreenDisplayLevel"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            SelectionChanged="OnScreenDisplayLevel_SelectionChanged">
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevel_Disabled}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevel_Minimal}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevel_Extended}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevel_Full}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevel_Custom}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayLevel_External}" />
                        </ComboBox>
                        <ui:SettingsExpander.Items>
                            <ui:SettingsCard
                                Description="{l:Static resx:Resources.OverlayPage_TimeLevelDesc}"
                                Header="{l:Static resx:Resources.OverlayPage_TimeLevel}"
                                IsEnabled="{Binding IsCustomOnScreenDisplayLevelEnabled}">
                                <ComboBox
                                    Name="ComboBoxOnScreenDisplayTimeLevel"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    SelectionChanged="ComboBoxOnScreenDisplayTimeLevel_SelectionChanged">
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Disabled}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Minimal}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Full}" />
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Description="{l:Static resx:Resources.OverlayPage_FPSLevelDesc}"
                                Header="{l:Static resx:Resources.OverlayPage_FPSLevel}"
                                IsEnabled="{Binding IsCustomOnScreenDisplayLevelEnabled}">
                                <ComboBox
                                    Name="ComboBoxOnScreenDisplayFPSLevel"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    SelectionChanged="ComboBoxOnScreenDisplayFPSLevel_SelectionChanged">
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Disabled}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Minimal}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Full}" />
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Description="{l:Static resx:Resources.OverlayPage_CPULevelDesc}"
                                Header="{l:Static resx:Resources.OverlayPage_CPULevel}"
                                IsEnabled="{Binding IsCustomOnScreenDisplayLevelEnabled}">
                                <ComboBox
                                    Name="ComboBoxOnScreenDisplayCPULevel"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    SelectionChanged="ComboBoxOnScreenDisplayCPULevel_SelectionChanged">
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Disabled}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Minimal}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Full}" />
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Description="{l:Static resx:Resources.OverlayPage_RAMLevelDesc}"
                                Header="{l:Static resx:Resources.OverlayPage_RAMLevel}"
                                IsEnabled="{Binding IsCustomOnScreenDisplayLevelEnabled}">
                                <ComboBox
                                    Name="ComboBoxOnScreenDisplayRAMLevel"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    SelectionChanged="ComboBoxOnScreenDisplayRAMLevel_SelectionChanged">
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Disabled}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Minimal}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Full}" />
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Description="{l:Static resx:Resources.OverlayPage_GPULevelDesc}"
                                Header="{l:Static resx:Resources.OverlayPage_GPULevel}"
                                IsEnabled="{Binding IsCustomOnScreenDisplayLevelEnabled}">
                                <ComboBox
                                    Name="ComboBoxOnScreenDisplayGPULevel"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    SelectionChanged="ComboBoxOnScreenDisplayGPULevel_SelectionChanged">
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Disabled}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Minimal}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Full}" />
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Description="{l:Static resx:Resources.OverlayPage_VRAMLevelDesc}"
                                Header="{l:Static resx:Resources.OverlayPage_VRAMLevel}"
                                IsEnabled="{Binding IsCustomOnScreenDisplayLevelEnabled}">
                                <ComboBox
                                    Name="ComboBoxOnScreenDisplayVRAMLevel"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    SelectionChanged="ComboBoxOnScreenDisplayVRAMLevel_SelectionChanged">
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Disabled}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Minimal}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Full}" />
                                </ComboBox>
                            </ui:SettingsCard>

                            <ui:SettingsCard
                                Description="{l:Static resx:Resources.OverlayPage_BATTLevelDesc}"
                                Header="{l:Static resx:Resources.OverlayPage_BATTLevel}"
                                IsEnabled="{Binding IsCustomOnScreenDisplayLevelEnabled}">
                                <ComboBox
                                    Name="ComboBoxOnScreenDisplayBATTLevel"
                                    HorizontalAlignment="Stretch"
                                    IsReadOnly="True"
                                    SelectionChanged="ComboBoxOnScreenDisplayBATTLevel_SelectionChanged">
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Disabled}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Minimal}" />
                                    <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_OverlayDisplayCustomLevel_Full}" />
                                </ComboBox>
                            </ui:SettingsCard>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </ikw:SimpleStackPanel>
            </ikw:SimpleStackPanel>

            <!--  Controller options  -->
            <ikw:SimpleStackPanel Spacing="8">
                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource BaseTextBlockStyle}"
                        Text="{l:Static resx:Resources.OverlayPage_ControllerOptions}" />
                    <TextBlock
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        Text="Model, alignment, size, opacity and render settings" />
                </DockPanel>

                <ikw:SimpleStackPanel Spacing="3">
                    <!--  Controller model  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_OverlayModelDesc}" Header="{l:Static resx:Resources.OverlayPage_OverlayModel}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xF158;" />
                        </ui:SettingsCard.HeaderIcon>
                        <ComboBox
                            Name="OverlayModel"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            SelectionChanged="OverlayModel_SelectionChanged">
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_DualSenseController}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_DualShock4Controller}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_8BitDoLite2Controller}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_N64Controller}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_SteamDeck}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_ToyController}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_Xbox360Controller}" />
                            <ComboBoxItem Content="{l:Static resx:Resources.OverlayPage_XboxOneController}" />
                        </ComboBox>
                    </ui:SettingsCard>

                    <!--  Controller Alignment  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_AlignmentDesc}" Header="{l:Static resx:Resources.OverlayPage_Alignment}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE80A;" />
                        </ui:SettingsCard.HeaderIcon>
                        <Grid HorizontalAlignment="Left">
                            <ikw:SimpleStackPanel
                                Name="OverlayControllerAlignment"
                                HorizontalAlignment="Right"
                                Spacing="3">
                                <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="3">
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="0" />
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="1" />
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="2" />
                                </ikw:SimpleStackPanel>
                                <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="3">
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="3" />
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="4" />
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="5" />
                                </ikw:SimpleStackPanel>
                                <ikw:SimpleStackPanel Orientation="Horizontal" Spacing="3">
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="6" />
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="7" />
                                    <Button
                                        Width="50"
                                        Height="50"
                                        Click="ControllerAlignment_Click"
                                        Tag="8" />
                                </ikw:SimpleStackPanel>
                            </ikw:SimpleStackPanel>
                        </Grid>
                    </ui:SettingsCard>

                    <!--  Size  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_SizeDesc}" Header="{l:Static resx:Resources.OverlayPage_Size}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xECC6;" />
                        </ui:SettingsCard.HeaderIcon>
                        <DockPanel>
                            <TextBox
                                Height="31"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                IsReadOnly="True"
                                Text="{Binding Value, StringFormat={}{0:N0} px, ElementName=SliderControllerSize, Mode=OneWay}" />
                            <Slider
                                x:Name="SliderControllerSize"
                                Width="200"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                IsSnapToTickEnabled="True"
                                LargeChange="100"
                                Maximum="800"
                                Minimum="200"
                                SmallChange="50"
                                TickFrequency="50"
                                TickPlacement="BottomRight"
                                ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                ValueChanged="SliderControllerSize_ValueChanged" />
                        </DockPanel>
                    </ui:SettingsCard>

                    <!--  Opacity  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_OpacityControllerDesc}" Header="{l:Static resx:Resources.OverlayPage_Opacity}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE75C;" />
                        </ui:SettingsCard.HeaderIcon>
                        <DockPanel>
                            <TextBox
                                Height="31"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                IsReadOnly="True"
                                Text="{Binding Value, StringFormat={}{0:N1}, ElementName=SliderControllerOpacity, Mode=OneWay}" />
                            <Slider
                                x:Name="SliderControllerOpacity"
                                Width="200"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                AutoToolTipPrecision="1"
                                IsMoveToPointEnabled="True"
                                IsSnapToTickEnabled="True"
                                LargeChange="0.2"
                                Maximum="1"
                                Minimum="0.1"
                                SmallChange="0.1"
                                TickFrequency="0.1"
                                TickPlacement="BottomRight"
                                ToolTip="{Binding Value, StringFormat=N1, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                ValueChanged="SliderControllerOpacity_ValueChanged" />
                        </DockPanel>
                    </ui:SettingsCard>

                    <!--  Background color  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_ColorDesc}" Header="{l:Static resx:Resources.OverlayPage_Color}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE790;" />
                        </ui:SettingsCard.HeaderIcon>
                        <DockPanel>
                            <colorpicker:PortableColorPicker
                                Name="ColorPicker"
                                ColorChanged="StandardColorPicker_ColorChanged"
                                Style="{StaticResource DefaultColorPickerStyle}" />
                        </DockPanel>
                    </ui:SettingsCard>

                    <!--  AlwaysOnTop  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_AlwaysOnTopDesc}" Header="{l:Static resx:Resources.OverlayPage_AlwaysOnTop}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE11C;" />
                        </ui:SettingsCard.HeaderIcon>
                        <ui:ToggleSwitch Name="Toggle_AlwaysOnTop" Toggled="Toggle_AlwaysOnTop_Toggled" />
                    </ui:SettingsCard>

                    <!--  Resting pitch  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_CameraAnglePitchDesc}" Header="{l:Static resx:Resources.OverlayPage_CameraAnglePitch}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xED3D;" />
                        </ui:SettingsCard.HeaderIcon>
                        <DockPanel>
                            <TextBox
                                Height="31"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                IsReadOnly="True"
                                Text="{Binding Value, StringFormat={}{0:N0} °, ElementName=Slider_RestingPitch, Mode=OneWay}" />
                            <Slider
                                x:Name="Slider_RestingPitch"
                                Width="200"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                AutoToolTipPrecision="1"
                                IsMoveToPointEnabled="True"
                                IsSnapToTickEnabled="True"
                                LargeChange="10"
                                Maximum="90"
                                Minimum="-90"
                                SmallChange="5"
                                TickFrequency="5"
                                TickPlacement="BottomRight"
                                ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                ValueChanged="Slider_RestingPitch_ValueChanged" />
                        </DockPanel>
                    </ui:SettingsCard>

                    <!--  Motion Activated  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_MotionActivatedDesc}" Header="{l:Static resx:Resources.OverlayPage_MotionActivated}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE895;" />
                        </ui:SettingsCard.HeaderIcon>
                        <ui:ToggleSwitch
                            Name="Toggle_MotionActivated"
                            IsOn="True"
                            Toggled="Toggle_MotionActivated_Toggled" />
                    </ui:SettingsCard>

                    <!--  FaceCamera  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_FaceCameraDesc}" Header="{l:Static resx:Resources.OverlayPage_FaceCamera}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE89E;" />
                        </ui:SettingsCard.HeaderIcon>
                        <ui:ToggleSwitch
                            Name="Toggle_FaceCamera"
                            IsEnabled="True"
                            Toggled="Toggle_FaceCamera_Toggled" />
                    </ui:SettingsCard>

                    <!--  Model settings  -->
                    <ui:SettingsExpander
                        HorizontalAlignment="Stretch"
                        Description="{l:Static resx:Resources.OverlayPage_RenderSettingsDesc}"
                        Expanded="Expander_Expanded"
                        Header="{l:Static resx:Resources.OverlayPage_RenderSettings}">
                        <ui:SettingsExpander.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE8B4;" />
                        </ui:SettingsExpander.HeaderIcon>
                        <ui:SettingsExpander.Items>
                            <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_RenderSettingsFramerateDesc}" Header="{l:Static resx:Resources.OverlayPage_RenderSettingsFramerate}">
                                <DockPanel>
                                    <TextBox
                                        Height="31"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        IsReadOnly="True"
                                        Text="{Binding OverlayRenderInterval, StringFormat={}{0:N0} FPS, Mode=OneWay}" />
                                    <Slider
                                        x:Name="Slider_Framerate"
                                        Width="200"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        IsMoveToPointEnabled="True"
                                        IsSnapToTickEnabled="True"
                                        LargeChange="10"
                                        Maximum="60"
                                        Minimum="10"
                                        SmallChange="5"
                                        TickFrequency="5"
                                        TickPlacement="BottomRight"
                                        ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                        ValueChanged="Slider_Framerate_ValueChanged"
                                        Value="{Binding OverlayRenderInterval, Mode=TwoWay}" />
                                </DockPanel>
                            </ui:SettingsCard>

                            <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_RenderSettingsAntialiasingDesc}" Header="{l:Static resx:Resources.OverlayPage_RenderSettingsAntialiasing}">
                                <ui:ToggleSwitch
                                    Name="Toggle_RenderAA"
                                    IsOn="False"
                                    Toggled="Toggle_RenderAA_Toggled" />
                            </ui:SettingsCard>
                        </ui:SettingsExpander.Items>
                    </ui:SettingsExpander>
                </ikw:SimpleStackPanel>
            </ikw:SimpleStackPanel>

            <!--  Trackpads options  -->
            <ikw:SimpleStackPanel Spacing="8">
                <DockPanel>
                    <TextBlock
                        VerticalAlignment="Center"
                        Style="{StaticResource BaseTextBlockStyle}"
                        Text="{l:Static resx:Resources.OverlayPage_TrackpadsOptions}" />
                    <TextBlock
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        Text="Position, size and opacity of the touchpad overlay" />
                </DockPanel>

                <ikw:SimpleStackPanel Spacing="3">
                    <!--  Controller Alignment  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_AlignmentTrackpadDesc}" Header="{l:Static resx:Resources.OverlayPage_Alignment}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE80A;" />
                        </ui:SettingsCard.HeaderIcon>
                        <Grid>
                            <ikw:SimpleStackPanel
                                Name="OverlayTrackpadsAlignment"
                                HorizontalAlignment="Right"
                                Spacing="3">
                                <Button
                                    Width="50"
                                    Height="50"
                                    Click="TrackpadsAlignment_Click"
                                    Tag="0" />
                                <Button
                                    Width="50"
                                    Height="50"
                                    Click="TrackpadsAlignment_Click"
                                    Tag="1" />
                                <Button
                                    Width="50"
                                    Height="50"
                                    Click="TrackpadsAlignment_Click"
                                    Tag="2" />
                            </ikw:SimpleStackPanel>
                        </Grid>
                    </ui:SettingsCard>

                    <!--  Size  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_SizeOverlayDesc}" Header="{l:Static resx:Resources.OverlayPage_Size}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xECC6;" />
                        </ui:SettingsCard.HeaderIcon>
                        <DockPanel>
                            <TextBox
                                Height="31"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                IsReadOnly="True"
                                Text="{Binding Value, StringFormat={}{0:N0} px, ElementName=SliderTrackpadsSize, Mode=OneWay}" />
                            <Slider
                                x:Name="SliderTrackpadsSize"
                                Width="200"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True"
                                IsSnapToTickEnabled="True"
                                LargeChange="100"
                                Maximum="800"
                                Minimum="100"
                                SmallChange="50"
                                TickFrequency="50"
                                TickPlacement="BottomRight"
                                ToolTip="{Binding Value, StringFormat=N0, RelativeSource={RelativeSource Self}, Mode=OneWay}"
                                ValueChanged="SliderTrackpadsSize_ValueChanged" />
                        </DockPanel>
                    </ui:SettingsCard>

                    <!--  Opacity  -->
                    <ui:SettingsCard Description="{l:Static resx:Resources.OverlayPage_OpacityTrackpadDesc}" Header="{l:Static resx:Resources.OverlayPage_Opacity}">
                        <ui:SettingsCard.HeaderIcon>
                            <ui:FontIcon FontFamily="{DynamicResource SymbolThemeFontFamily}" Glyph="&#xE75C;" />
                        </ui:SettingsCard.HeaderIcon>
                        <DockPanel>
                            <TextBox
                                Height="31"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                IsReadOnly="True"
                                Text="{Binding Value, StringFormat={}{0:N1}, ElementName=SliderTrackpadsOpacity, Mode=OneWay}" />
                            <Slider
                                x:Name="SliderTrackpadsOpacity"
                                Width="200"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                AutoToolTipPrecision="1"
                                IsMoveToPointEnabled="True"
                                IsSnapToTickEnabled="True"
                                LargeChange="0.1"
                                Maximum="0.25"
                                Minimum="0.01"
                                SmallChange="0.01"
                                TickFrequency="0.01"
                                TickPlacement="BottomRight"
